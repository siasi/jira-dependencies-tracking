jira:
  instance: "your-company.atlassian.net"

projects:
  initiatives: "INIT"
  teams:
    - "TEAM1"
    - "TEAM2"

# Custom fields to extract from initiatives
# Add any Jira custom field here - no code changes needed
# Format: output_name: "customfield_XXXXX"
custom_fields:
  initiatives:
    rag_status: "customfield_XXXXX"           # Select field example
    strategic_objective: "customfield_XXXXX"  # Text field example
    quarter: "customfield_XXXXX"              # Required if using --quarter flag

# DEPRECATED: Filters moved to command-line options
# Use --quarter and --status flags instead:
#   python3 jira_extract.py extract --quarter "26 Q2" --status "In Progress"
# filters:
#   quarter: "25 Q1"  # Format: "YY QN" (e.g., "25 Q1", "25 Q2")

# Validation rules for initiative fields
# Used by validate_strategic_objective.py and other validation scripts
validation:
  strategic_objective:
    valid_values:
      - "Revenue Growth"
      - "Cost Reduction"
      - "Customer Experience"
      - "Operational Excellence"
      - "Risk Management"
      - "Innovation"
      # Add your organization's strategic objectives here

output:
  directory: "./data"
  filename_pattern: "jira_extract_{timestamp}.json"
