# Team name mappings for validation
# Maps display names (from Teams Involved field) to project keys (from epics)
#
# Format:
#   "Display Name": "PROJECT_KEY"
#
# This mapping is used to identify which teams need to create epics
# when there's a mismatch between Teams Involved and actual epics.

team_mappings:
  "CBP": "CBPPE"
  "Console": "CONSOLE"
  "Core Banking": "CBNK"
  "Identity": "DNTT"
  "MAP": "MAPS"
  "PAYIN": "PAYINS"
  "Payments Payins": "PAYINS"  # Alternative display name
  "Payments Experience": "PX"
  "Payments Risk": "RSK"
  "Analytics" : "Analytics"
  "Integration Ops" : "DOCS"
  "User Network" : "PLAT"

  # Teams not yet seen with epics - add mapping when they appear
  # "BOT": "???"

# Engineering manager Notion handles and Slack IDs for team notifications
# Maps project keys to manager information (for @mentions and Dust DMs)
#
# Format:
#   "PROJECT_KEY":
#     notion_handle: "@notion.handle"
#     slack_id: "U_SLACK_ID"
#
# These are used to tag managers in reports and send Dust messages
