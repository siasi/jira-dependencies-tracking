# Team name mappings for validation (EXAMPLE)
# Maps display names (from Teams Involved field) to project keys (from epics)
#
# Format:
#   "Display Name": "PROJECT_KEY"
#
# This mapping is used to identify which teams need to create epics
# when there's a mismatch between Teams Involved and actual epics.
#
# SETUP:
# 1. Copy this file to team_mappings.yaml
# 2. Replace with your actual team names and project keys
# 3. The file is optional - script works without it (uses display names as-is)

team_mappings:
  "Team A": "TEAMA"
  "Team B": "TEAMB"
  "Team C": "TEAMC"
  "Engineering": "ENG"
  "Product": "PROD"

  # Add more mappings as needed
  # "Display Name": "PROJECT_KEY"

# Engineering manager Notion handles for team notifications (OPTIONAL)
# Maps project keys to manager Notion handles (for @mentions in markdown)
#
# Format:
#   "PROJECT_KEY": "@notion.handle"
#
# These handles are used to tag managers in markdown reports for action items.
# When set, managers will be @mentioned in Notion for their team's action items:
# - Missing dependencies (team needs to create epics)
# - Missing RAG status (team needs to set RAG status)
# - Missing strategic objective (initiative owner team's manager)
# - No assignee (initiative owner team's manager)
team_managers:
  "TEAMA": "@manager.teama"
  "TEAMB": "@manager.teamb"
  "TEAMC": "@manager.teamc"
  "ENG": "@manager.engineering"
  "PROD": "@manager.product"

  # Add more manager handles as needed
  # "PROJECT_KEY": "@notion.handle"

# My teams for filtering action items (OPTIONAL)
# List of project keys for teams you manage
#
# Use case:
# - When running validate_data_quality.py with --me flag, only show action items
#   for your teams instead of all teams
#
# Format:
#   - "PROJECT_KEY"
#
# Example:
#   my_teams:
#     - "TEAMA"
#     - "TEAMB"
#
# Usage:
#   python validate_data_quality.py --quarter "26 Q2" --me
#
# Note: Slack output (--slack) is not affected and always shows all teams
my_teams:
  - "TEAMA"
  - "TEAMB"

  # Add your team project keys here
  # - "PROJECT_KEY"

# Teams exempt from RAG status checking (OPTIONAL)
# List of project keys for teams that don't need to report RAG status
#
# Use cases:
# - Supporting teams (Integration Ops, DOCS, etc.)
# - Teams that provide documentation or operational support
# - Owner teams are automatically exempt (don't add them here)
#
# Format:
#   - "PROJECT_KEY"
#
# These teams' epics will not be checked for RED/YELLOW/missing RAG status.
# They still need to create epics if listed in Teams Involved.
teams_exempt_from_rag:
  - "Integration Ops"
  - "DOCS"

  # Add more exempt teams as needed
  # - "PROJECT_KEY"

# Teams to exclude from workload analysis (OPTIONAL)
# Used by analyze_workload.py to filter out teams with different work patterns
#
# Use cases:
# - DevOps and Integration Ops (different workload patterns than product teams)
# - Infrastructure and operations teams
# - Teams that don't follow standard initiative-based planning
#
# Format:
#   - "Team Display Name"
#
# Note: These teams are excluded from workload metrics but still included
# in planning validation (they still need epics if listed in Teams Involved).
teams_excluded_from_workload_analysis:
  - "IT"
  - "Security Engineering"
  - "DevOps"
  - "Integration Ops"
  - "CBP Platform"

  # Add more excluded teams as needed
  # - "Team Display Name"

# Teams to exclude from validation checks (OPTIONAL)
# Used by validate_planning.py to filter out teams that don't create epics
#
# Use cases:
# - Teams that don't follow the standard epic creation process
# - External or consulting teams
# - Legacy or deprecated teams
#
# Format:
#   - "Team Display Name"
#
# Note: These teams are excluded from epic validation checks entirely.
teams_excluded_from_validation:
  - "IT"
  - "Security Engineering"

  # Add more excluded teams as needed
  # - "Team Display Name"

# DEPRECATED: Use teams_excluded_from_workload_analysis or teams_excluded_from_validation instead
# This is kept for backward compatibility. If the specific lists above are not defined,
# scripts will fall back to this list.
teams_excluded_from_analysis:
  - "IT"
  - "Security Engineering"

  # Add more excluded teams as needed (but prefer using specific lists above)
  # - "Team Display Name"
