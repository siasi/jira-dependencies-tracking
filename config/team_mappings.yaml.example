# Teams to exclude from analysis entirely
# Initiatives with these teams as owner_team will be filtered out
teams_excluded_from_analysis:
  - "IT"
  - "Security Engineering"
  - "SecOps"
  - "EngOps"
  - "Analytics Tooling & Integrations"
  - "Governance Risk & Compliance"
  - "Plugins (Ecomm)"
  - "CBP Recurring Payments"
  - "OBX Germany"

# Strategic objective mappings - consolidate old objectives to current ones
# Format:
#   "old_objective": "new_objective"
#
# This maps historical strategic objectives to current ones for consistent
# reporting. The workload analysis will show only the mapped (current) objectives.
strategic_objective_mappings:
  # 2023 objectives -> 2026 objectives
  "2023_5_Optimise Operations": "engineering_pillars"
  # 2024 objectives -> 2026 objectives
  "2024_1 Scale iGaming and FS": "2026_fuel_regulated"
  "2024_2 Win eCommerce": "2026_scale_ecom"
  "2024_4 Reach operating maturity": "2026_fuel_regulated"
  # 2025 objectives -> 2026 objectives
  "2025_increase_soc_conversion": "2026_scale_ecom"
  "2025_increase_soc_adoption": "2026_scale_ecom"
  "2025_recurring_payments": "2026_scale_ecom"
  "2025_FR_DE_payments": "2026_fuel_regulated"
  "2025_fraud_and_risk": "2026_network"
  "2025_scalability_and_reliability": "engineering_pillars"
  "2025_non_strategic_objective": "beyond_strategic"
  # Keep current objectives as-is (identity mappings)
  "2026_fuel_regulated": "2026_fuel_regulated"
  "2026_scale_ecom": "2026_scale_ecom"
  "2026_network": "2026_network"
  "2026_recurring_payments": "2026_recurring_payments"
  "engineering_pillars": "engineering_pillars"
  "beyond_strategic": "beyond_strategic"