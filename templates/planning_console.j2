🎯 PLANNED/IN PROGRESS FOR THE QUARTER ({{ result.planned_for_quarter|length }} initiatives)

{% if result.planned_for_quarter -%}
{%- set red_initiatives = [] -%}
{%- set yellow_initiatives = [] -%}
{%- set green_initiatives = [] -%}
{%- for item in result.planned_for_quarter -%}
{%- if item.get('has_red_epics') -%}
{%- set _ = red_initiatives.append(item) -%}
{%- elif item.get('has_yellow_epics') -%}
{%- set _ = yellow_initiatives.append(item) -%}
{%- else -%}
{%- set _ = green_initiatives.append(item) -%}
{%- endif -%}
{%- endfor -%}

{%- if red_initiatives %}
