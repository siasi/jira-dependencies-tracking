{# Console output template for initiative validation report #}
{# Input: result (ValidationResult), json_file (Path), verbose (bool), team_mappings (Dict), team_managers (Dict), reverse_team_mappings (Dict) #}

================================================================================
Initiative Planning Readiness Tracker
================================================================================

Quarter: {{ result.quarter }}
Data source: {{ json_file }}
Filter: Multi-team initiatives only (teams >= 2)
Total initiatives in file: {{ result.total_checked + result.total_filtered }}
Multi-team initiatives analyzed: {{ result.total_checked }}
{% if result.total_filtered > 0 -%}
Single-team initiatives skipped: {{ result.total_filtered }}
{% endif -%}

Summary:
  📋 Dependency Mapping in Progress: {{ result.dependency_mapping|length }} initiatives
  🟡 No/Low confidence for completion - require discussion: {{ result.low_confidence_completion|length }} initiatives
  ✅ Ready to Move to Planned: {{ result.ready_to_plan|length }} initiatives
  🎯 Planned/In Progress for the Quarter: {{ result.planned_for_quarter|length }} initiatives
{%- set red_count = result.planned_for_quarter|selectattr('has_red_epics', 'equalto', true)|list|length -%}
{%- set yellow_count = result.planned_for_quarter|rejectattr('has_red_epics', 'equalto', true)|selectattr('has_yellow_epics', 'equalto', true)|list|length -%}
{%- set green_count = result.planned_for_quarter|length - red_count - yellow_count %}

{%- if red_count > 0 %}
     🔴 Won't Complete: {{ red_count }}
{%- endif -%}
{%- if yellow_count > 0 %}
     🟡 Low Confidence: {{ yellow_count }}
{%- endif -%}
{%- if green_count > 0 %}
     ✅ Fully Committed: {{ green_count }}
{%- endif %}
{% if verbose and result.ignored_statuses %}
  ⏭️  Not Analyzed: {{ result.ignored_statuses|length }} initiatives
{% endif %}

--------------------------------------------------------------------------------

📋 DEPENDENCY MAPPING IN PROGRESS ({{ result.dependency_mapping|length }} initiatives)

Action required: Create missing epics and set initial RAG status

{% if result.dependency_mapping -%}
{% for item in result.dependency_mapping -%}
{{ item.key|hyperlink(item.url) }}: {{ item.summary }}

{% for issue in item.issues -%}
{% if issue.type == 'missing_assignee' %}
   ⚠️  Missing Assignee - Action:
{% set owner_team = item.get('owner_team') -%}
{%- set manager_tag = '' -%}
{%- if owner_team -%}
{%- set project_key = team_mappings.get(owner_team, owner_team) -%}
{%- set manager_info = team_managers.get(project_key, {}) -%}
{%- set manager_tag = manager_info.get('notion_handle', '') -%}
{%- endif -%}
{%- set manager_suffix = ' ' + manager_tag if manager_tag else '' %}
       [ ] Set the assignee/owner for the initiative{{ manager_suffix }}

{% elif issue.type == 'missing_strategic_objective' %}
   ⚠️  Missing Strategic Objective - Action:
{% set owner_team = item.get('owner_team') -%}
{%- set manager_tag = '' -%}
{%- if owner_team -%}
{%- set project_key = team_mappings.get(owner_team, owner_team) -%}
{%- set manager_info = team_managers.get(project_key, {}) -%}
{%- set manager_tag = manager_info.get('notion_handle', '') -%}
{%- endif -%}
{%- set manager_suffix = ' ' + manager_tag if manager_tag else '' %}
       [ ] Set the Strategic Objective field for this initiative{{ manager_suffix }}

{% elif issue.type == 'invalid_strategic_objective' %}
   ⚠️  Invalid Strategic Objective - Action:
{% set owner_team = item.get('owner_team') -%}
{%- set manager_tag = '' -%}
{%- if owner_team -%}
{%- set project_key = team_mappings.get(owner_team, owner_team) -%}
{%- set manager_info = team_managers.get(project_key, {}) -%}
{%- set manager_tag = manager_info.get('notion_handle', '') -%}
{%- endif -%}
{%- set manager_suffix = ' ' + manager_tag if manager_tag else '' %}
       Current value: "{{ issue.current_value }}"
       [ ] Update to a valid strategic objective{{ manager_suffix }}

{% elif issue.type == 'epic_count_mismatch' -%}
{%- set epic_keys = [] -%}
{%- for tc in item.contributing_teams -%}
{%- for epic in tc.get('epics', []) -%}
{%- set _ = epic_keys.append(epic.key) -%}
{%- endfor -%}
{%- endfor -%}
{%- set teams_count = issue.teams_involved|length -%}
{%- set epics_count = issue.teams_with_epics|length %}
   ⚠️  Missing dependencies - Action:
{% if epics_count < teams_count -%}
{%- set teams_with_epics_set = issue.teams_with_epics -%}
{%- set owner_team = item.get('owner_team') -%}
{%- set missing_teams = [] -%}
{%- for display_name in issue.teams_involved -%}
{%- if not (owner_team and display_name == owner_team) -%}
{%- set project_key = team_mappings.get(display_name) -%}
{%- if project_key and project_key not in teams_with_epics_set -%}
{%- set _ = missing_teams.append((display_name + ' (' + project_key + ')', project_key)) -%}
{%- elif not project_key and display_name not in teams_with_epics_set -%}
{%- set _ = missing_teams.append((display_name + ' (unmapped)', None)) -%}
{%- endif -%}
{%- endif -%}
{%- endfor -%}
{%- if missing_teams -%}
{%- for team_str, project_key in missing_teams -%}
{%- set manager_info = team_managers.get(project_key, {}) if project_key else {} -%}
{%- set manager_tag = manager_info.get('notion_handle', '') -%}
{%- set manager_suffix = ' ' + manager_tag if manager_tag else '' %}
       [ ] {{ team_str }} to create epic{{ manager_suffix }}
{% endfor %}
{% else -%}
{%- set missing_count = teams_count - epics_count %}
       - Action: Create {{ missing_count }} missing epic{% if missing_count > 1 %}s{% endif %} or update Teams Involved field
{% endif -%}
{% elif epics_count > teams_count -%}
{%- set teams_involved_keys = [] -%}
{%- for display_name in issue.teams_involved -%}
{%- set project_key = team_mappings.get(display_name) -%}
{%- if project_key -%}
{%- set _ = teams_involved_keys.append(project_key.upper()) -%}
{%- else -%}
{%- set _ = teams_involved_keys.append(display_name.upper()) -%}
{%- endif -%}
{%- endfor -%}
{%- set extra_teams = [] -%}
{%- for key in issue.teams_with_epics -%}
{%- if key.upper() not in teams_involved_keys -%}
{%- set _ = extra_teams.append(key) -%}
{%- endif -%}
{%- endfor -%}
{% if extra_teams %}
       - Action: Add {{ extra_teams|join(', ') }} to Teams Involved field
{% else %}
       - Action: Update Teams Involved field to include all {{ epics_count }} teams with epics
{% endif -%}
{%- endif %}

{% elif issue.type == 'missing_rag_status' %}
   ⚠️  Missing RAG status - Action:
{% for team_data in issue.teams -%}
{%- set team_name = team_data.team_name -%}
{%- set team_key = team_data.team_key -%}
{%- set epic_links = [] -%}
{%- for epic in team_data.epics -%}
{%- set _ = epic_links.append(epic.key|hyperlink(epic.url)) -%}
{%- endfor -%}
{%- set epics_str = epic_links|join(', ') -%}
{%- set display_name = reverse_team_mappings.get(team_key, team_name) -%}
{%- set manager_info = team_managers.get(team_key, {}) -%}
{%- set manager_tag = manager_info.get('notion_handle', '') -%}
{%- set manager_suffix = ' ' + manager_tag if manager_tag else '' %}
       [ ] {{ display_name }} to set RAG status for {{ epics_str }}{{ manager_suffix }}
{% endfor %}

{%- endif -%}
{% endfor %}

{% endfor -%}
{%- else %}
No initiatives currently in dependency mapping phase.

{%- endif %}
--------------------------------------------------------------------------------

🟡 NO/LOW CONFIDENCE FOR COMPLETION - REQUIRE DISCUSSION ({{ result.low_confidence_completion|length }} initiatives)

Action required: PM/EM to confirm working on initiative (move to PLANNED) or
deprioritise it (move to DEPRIORITISED)

{% if result.low_confidence_completion -%}
{% for item in result.low_confidence_completion -%}
{{ item.key|hyperlink(item.url) }}: {{ item.summary }}

{% for issue in item.issues -%}
{% if issue.type == 'red_epics' %}
   🔴 Epics with RED status ({{ issue.epics|length }})
{% for epic in issue.epics -%}
{% set rag_display = '🔴' if epic.rag_status == '🔴' else '(missing - treated as RED)' %}
       - {{ rag_display }} {{ epic.key|hyperlink(epic.url) }}: "{{ epic.summary }}"
{% endfor %}

{% elif issue.type == 'yellow_epics' %}
   🟡 Epics with YELLOW status ({{ issue.epics|length }})
{% for epic in issue.epics -%}
{% set rag_display = '🟡' if epic.get('rag_status') else '(missing - treated as YELLOW)' %}
       - {{ rag_display }} {{ epic.key|hyperlink(epic.url) }}: "{{ epic.summary }}"
{% endfor %}

{%- endif -%}
{% endfor %}
{% set owner_team = item.get('owner_team') -%}
{%- set manager_tag = '' -%}
{%- if owner_team -%}
{%- set project_key = team_mappings.get(owner_team, owner_team) -%}
{%- set manager_info = team_managers.get(project_key, {}) -%}
{%- set manager_tag = manager_info.get('notion_handle', '') -%}
{%- endif -%}
{%- set manager_suffix = ' ' + manager_tag if manager_tag else '' %}
   ⚠️  Action:
       [ ] Clarify final decision (PLANNED or DEPRIORITISED){{ manager_suffix }}

{% endfor -%}
{% else %}
No initiatives with no/low confidence for completion at this time.

{% endif %}
--------------------------------------------------------------------------------

✅ READY TO MOVE TO PLANNED ({{ result.ready_to_plan|length }} initiatives)

Action required: Update status to Planned in Jira (bulk keys provided below)

{% if result.ready_to_plan -%}
{% for item in result.ready_to_plan -%}
{{ item.key|hyperlink(item.url) }}: {{ item.summary }}
{% set owner_team = item.get('owner_team') -%}
{%- set manager_tag = '' -%}
{%- if owner_team -%}
{%- set project_key = team_mappings.get(owner_team, owner_team) -%}
{%- set manager_info = team_managers.get(project_key, {}) -%}
{%- set manager_tag = manager_info.get('notion_handle', '') -%}
{%- endif -%}
{%- set manager_suffix = ' ' + manager_tag if manager_tag else '' %}
   ✅ Action:
       [ ] Move initiative to PLANNED status{{ manager_suffix }}

{% endfor %}
Bulk update - Copy these issue keys for Jira:
{{ result.ready_to_plan|map(attribute='key')|join(',') }}
{%- else %}
No initiatives are ready to move to Planned status at this time.
{%- endif %}

