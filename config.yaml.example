jira:
  instance: "your-company.atlassian.net"

projects:
  initiatives: "INIT"
  teams:
    - "TEAM1"
    - "TEAM2"

# Custom fields to extract from initiatives
# Add any Jira custom field here - no code changes needed
# Format: output_name: "customfield_XXXXX"
custom_fields:
  initiatives:
    rag_status: "customfield_XXXXX"           # Select field example
    strategic_objective: "customfield_XXXXX"  # Text field example
    quarter: "customfield_XXXXX"              # Required if using filters.quarter

# Optional: Filter initiatives by quarter and status
# If omitted, all initiatives are extracted
filters:
  quarter: "25 Q1"  # Format: "YY QN" (e.g., "25 Q1", "25 Q2")

output:
  directory: "./data"
  filename_pattern: "jira_extract_{timestamp}.json"
