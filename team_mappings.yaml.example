# Team name mappings for validation (EXAMPLE)
# Maps display names (from Teams Involved field) to project keys (from epics)
#
# Format:
#   "Display Name": "PROJECT_KEY"
#
# This mapping is used to identify which teams need to create epics
# when there's a mismatch between Teams Involved and actual epics.
#
# SETUP:
# 1. Copy this file to team_mappings.yaml
# 2. Replace with your actual team names and project keys
# 3. The file is optional - script works without it (uses display names as-is)

team_mappings:
  "Team A": "TEAMA"
  "Team B": "TEAMB"
  "Team C": "TEAMC"
  "Engineering": "ENG"
  "Product": "PROD"

  # Add more mappings as needed
  # "Display Name": "PROJECT_KEY"

# Engineering manager Notion handles for team notifications (OPTIONAL)
# Maps project keys to manager Notion handles (for @mentions in markdown)
#
# Format:
#   "PROJECT_KEY": "@notion.handle"
#
# These handles are used to tag managers in markdown reports for action items.
# When set, managers will be @mentioned in Notion for their team's action items:
# - Missing dependencies (team needs to create epics)
# - Missing RAG status (team needs to set RAG status)
# - Missing strategic objective (initiative owner team's manager)
# - No assignee (initiative owner team's manager)
team_managers:
  "TEAMA": "@manager.teama"
  "TEAMB": "@manager.teamb"
  "TEAMC": "@manager.teamc"
  "ENG": "@manager.engineering"
  "PROD": "@manager.product"

  # Add more manager handles as needed
  # "PROJECT_KEY": "@notion.handle"

# Teams exempt from RAG status checking (OPTIONAL)
# List of project keys for teams that don't need to report RAG status
#
# Use cases:
# - Supporting teams (Integration Ops, DOCS, etc.)
# - Teams that provide documentation or operational support
# - Owner teams are automatically exempt (don't add them here)
#
# Format:
#   - "PROJECT_KEY"
#
# These teams' epics will not be checked for RED/YELLOW/missing RAG status.
# They still need to create epics if listed in Teams Involved.
teams_exempt_from_rag:
  - "Integration Ops"
  - "DOCS"

  # Add more exempt teams as needed
  # - "PROJECT_KEY"
